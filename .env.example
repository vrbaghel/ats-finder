# Notion API Token (Integration Token)
NOTION_TOKEN=secret_your_token_here

# Notion Database ID
DATABASE_ID=your_database_id_here

# Property Names in your Notion Database
# The script will detect the type (select vs rich_text/url) automatically.
COMPANY_PROPERTY_NAME=Name
ATS_PROPERTY_NAME=ATS
PORTAL_URL_PROPERTY_NAME=Job Portal URL
